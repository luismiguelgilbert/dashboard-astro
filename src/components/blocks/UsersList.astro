---
import { db } from '@/db';
type User = {
  user_name: string;
  user_lastname: string;
  avatar_url: string;
  id: number;
};
const response = await db.query(`select user_name, user_lastname, avatar_url, id
from sys_users a
where a.email like '%gilbert%'
and a.is_active = True
limit 5`);
const users = response.rows;
---

<h1 class="text-2xl font-bold mb-4">Users List</h1>
{users.map(user => (
  <div class="p-4 border rounded-lg">
    <h2 class="text-xl font-semibold">{user.user_name}</h2>
    <p class="text-gray-600">{user.user_lastname}</p>
  </div>
))}