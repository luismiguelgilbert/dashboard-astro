---
import type { User } from '@/pages/api/users.json';
const users: User[] = await (await fetch(new URL("/api/users.json", Astro.url))).json();
---

<h1 class="text-2xl font-bold mb-4">Users List</h1>
count: {users[0].total_count}

{users.map(user => (
  <div class="p-4 border rounded-lg">
    <h2 class="text-xl font-semibold">{user.user_name}</h2>
    <p class="text-gray-600">{user.user_lastname}</p>
  </div>
))}