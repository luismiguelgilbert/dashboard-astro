---
import '../styles/global.css';
import AppSidebar from '@/components/blocks/AppSidebar.vue';
interface Props {
  title: string;
  description?: string;
  publishDate?: string;
  viewCount?: number;
}
const { title } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body>
		<AppSidebar
			client:load
			title={title}>
			<slot />
		</AppSidebar>
	</body>
</html>
